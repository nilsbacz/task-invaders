{% extends 'base.html.twig' %}

{% block title %}{{ board.title }}{% endblock %}

{% block body %}
    <section class="hero-panel mb-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3">
            <div>
                <p class="eyebrow mb-2">Board detail</p>
                <h1 class="display-5 mb-2">{{ board.title }}</h1>
                <p class="lead mb-0">{{ board.isTurretMode ? 'Turret mode enabled.' : 'Standard board mode.' }}</p>
            </div>
            <a class="btn btn-outline-dark" href="{{ path('board_index') }}">Back to boards</a>
        </div>
    </section>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success" role="alert">{{ message }}</div>
    {% endfor %}

    <div class="board-layout align-items-start">
        <div class="board-sidebar">
            <section class="panel p-3 p-lg-4">
                <div class="section-heading mb-4">
                    <p class="eyebrow">Rows</p>
                    <h2 class="h3 mb-0">New row</h2>
                </div>
                {{ form_start(rowCreateForm) }}
                {{ form_row(rowCreateForm.title) }}
                {{ form_rest(rowCreateForm) }}
                <button class="btn btn-primary" type="submit">Add row</button>
                {{ form_end(rowCreateForm, { render_rest: false }) }}
            </section>
        </div>

        <div class="board-content">
            <section class="vstack gap-4">
                <div class="section-heading mb-0">
                    <p class="eyebrow">Rows</p>
                    <h2 class="h3 mb-0">Board structure</h2>
                </div>

                {% if board.boardRows is empty %}
                    <div class="panel p-4">
                        <p class="mb-0">No rows yet.</p>
                    </div>
                {% endif %}

                {% if board.boardRows is not empty %}
                    <div class="board-grid">
                        {% for row in board.boardRows %}
                            {% set updateForm = rowUpdateForms[row.id] %}
                            {% set deleteForm = rowDeleteForms[row.id] %}
                            {% set updateFormId = 'board-row-update-' ~ row.id %}
                            {% set deleteFormId = 'board-row-delete-' ~ row.id %}
                            <article class="panel board-card h-100 p-3">
                                <div class="mb-3">
                                    <p class="eyebrow mb-1">Row {{ row.rowNumber }}</p>
                                    <h3 class="h5 mb-0">{{ row.title }}</h3>
                                </div>

                                <div class="board-card-footer">
                                    {{ form_start(updateForm, { attr: { class: 'board-card-form board-card-form--update', id: updateFormId } }) }}
                                    {{ form_row(updateForm.title) }}
                                    {{ form_rest(updateForm) }}
                                    {{ form_end(updateForm, { render_rest: false }) }}

                                    {{ form_start(deleteForm, { attr: { class: 'board-card-form board-card-form--delete', id: deleteFormId } }) }}
                                    {{ form_rest(deleteForm) }}
                                    {{ form_end(deleteForm, { render_rest: false }) }}

                                    <div class="board-card-actions">
                                        <button class="btn btn-primary btn-sm" type="submit" form="{{ updateFormId }}">Update row</button>
                                        <button class="btn btn-outline-danger btn-sm" type="submit" form="{{ deleteFormId }}">Remove row</button>
                                    </div>
                                </div>

                                {% set taskCreateForm = taskCreateForms[row.id] ?? null %}
                                {% if taskCreateForm is not null %}
                                    <div class="mt-4">
                                        <p class="eyebrow mb-2">New task</p>
                                        {{ form_start(taskCreateForm, { attr: { class: 'board-card-form' } }) }}
                                        {% include 'boards/_task_form_fields.html.twig' with { form: taskCreateForm } only %}
                                        {{ form_rest(taskCreateForm) }}
                                        <button class="btn btn-primary btn-sm" type="submit">Add task</button>
                                        {{ form_end(taskCreateForm, { render_rest: false }) }}
                                    </div>
                                {% endif %}

                                <div class="mt-4">
                                    {% set activeTasks = row.activeTasks %}
                                    {% if activeTasks is empty %}
                                        <p class="text-body-secondary mb-0">No tasks yet.</p>
                                    {% else %}
                                        <ul class="list-group list-group-flush">
                                            {% for task in activeTasks %}
                                                {% set shootForm = shootForms[task.id] ?? null %}
                                                {% set taskUpdateForm = taskUpdateForms[task.id] ?? null %}
                                                {% set taskDeleteForm = taskDeleteForms[task.id] ?? null %}
                                                {% set taskUpdateFormId = 'task-update-' ~ task.id %}
                                                {% set taskDeleteFormId = 'task-delete-' ~ task.id %}
                                                <li class="list-group-item">
                                                    <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-between gap-3 mb-3">
                                                        <div>
                                                            <span class="fw-semibold">{{ task.title }}</span>
                                                            <div class="small text-body-secondary">
                                                                {{ task.riskLevel.value|lower|capitalize }} risk
                                                                {% if task.hasShield %} - Shielded{% endif %}
                                                            </div>
                                                        </div>
                                                        <div class="d-flex flex-wrap gap-2">
                                                            {% if shootForm is not null %}
                                                                {{ form_start(shootForm, { attr: { class: 'm-0' } }) }}
                                                                {{ form_rest(shootForm) }}
                                                                <button
                                                                    class="btn btn-primary btn-sm"
                                                                    type="submit"
                                                                    aria-label="Shoot {{ task.title }}"
                                                                >
                                                                    Shoot
                                                                </button>
                                                                {{ form_end(shootForm, { render_rest: false }) }}
                                                            {% endif %}

                                                            {% if taskDeleteForm is not null %}
                                                                {{ form_start(taskDeleteForm, { attr: { class: 'board-card-form board-card-form--delete', id: taskDeleteFormId } }) }}
                                                                {{ form_rest(taskDeleteForm) }}
                                                                {{ form_end(taskDeleteForm, { render_rest: false }) }}
                                                                <button class="btn btn-outline-danger btn-sm" type="submit" form="{{ taskDeleteFormId }}">
                                                                    Remove
                                                                </button>
                                                            {% endif %}
                                                        </div>
                                                    </div>

                                                    {% if taskUpdateForm is not null %}
                                                        {{ form_start(taskUpdateForm, { attr: { class: 'board-card-form', id: taskUpdateFormId } }) }}
                                                        {% include 'boards/_task_form_fields.html.twig' with { form: taskUpdateForm } only %}
                                                        {{ form_rest(taskUpdateForm) }}
                                                        {{ form_end(taskUpdateForm, { render_rest: false }) }}
                                                        <button class="btn btn-outline-dark btn-sm" type="submit" form="{{ taskUpdateFormId }}">
                                                            Update task
                                                        </button>
                                                    {% endif %}
                                                </li>
                                            {% endfor %}
                                        </ul>
                                    {% endif %}
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                {% endif %}
            </section>
        </div>
    </div>
{% endblock %}

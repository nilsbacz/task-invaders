<!DOCTYPE html>

<title>Hello BoardController!</title>

{% block body %}
    <style>
        .example-wrapper {
            margin: 1em auto;
            max-width: 800px;
            width: 95%;
            font: 18px/1.5 sans-serif;
        }

        .example-wrapper code {
            background: #F5F5F5;
            padding: 2px 6px;
        }
    </style>

    <div class="example-wrapper">
        <h1>Hello BoardController! Board ID: {{ board.id }} ✅</h1>
    </div>

    {% block board_row_table %}
        <div class="example-wrapper">
            <h2>Rows:</h2>
            <ul>
                {% for row in board.getBoardRows() %}
                    <li>{{ row.title }}</li>
                {% endfor %}
            </ul>
        </div>
    {% endblock %}
{% endblock %}
